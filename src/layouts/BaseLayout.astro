---
import { ClientRouter } from "astro:transitions";
import "../styles/globals.css";
import type { Lang } from "../i18n/utils";
import { alternatePath } from "../i18n/utils";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: Lang;
}

const {
  title = "Enterprisebrain.eu — KI mit SAP-Integration",
  description = "Maßgeschneiderte Unternehmens-KI mit vollständiger SAP-Integration. Prozesse automatisieren, Mitarbeitende entlasten, Effizienz steigern.",
  ogImage = "/og-image.jpg",
  noindex = false,
  lang = "de",
} = Astro.props;

const siteOrigin = new URL(
  import.meta.env.SITE_URL ?? "https://enterprisebrain.eu"
).origin;
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const ogImageURL = new URL(ogImage, siteOrigin);
const deUrl = new URL(
  lang === "de" ? Astro.url.pathname : alternatePath(Astro.url, "de"),
  siteOrigin,
);
const enUrl = new URL(
  lang === "en" ? Astro.url.pathname : alternatePath(Astro.url, "en"),
  siteOrigin,
);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Enterprisebrain.eu",
  url: siteOrigin,
  logo: {
    "@type": "ImageObject",
    url: `${siteOrigin}/logo.png`,
  },
  description:
    "Maßgeschneiderte KI-Lösung mit vollständiger SAP-Integration für Unternehmen.",
  email: "office@enterprisebrain.eu",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Towerstraße 3",
    addressLocality: "Wien-Flughafen",
    postalCode: "1300",
    addressCountry: "AT",
  },
  sameAs: ["https://www.linkedin.com/company/enterprisebrain"],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Enterprisebrain.eu",
  url: siteOrigin,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="de" href={deUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={deUrl} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f29202" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Enterprisebrain.eu" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === "en" ? "en_US" : "de_DE"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(organizationSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(websiteSchema)}
    />

    <ClientRouter />
  </head>
  <body>
    <slot />
    <script>
      function initScrollAnimations() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
              }
            });
          },
          { threshold: 0.08, rootMargin: "0px 0px -32px 0px" },
        );
        document.querySelectorAll("[data-animate]").forEach((el) => {
          observer.observe(el);
        });
      }

      function initNavbarScroll() {
        const navbar = document.getElementById("main-nav");
        if (!navbar) return;
        const onScroll = () => {
          navbar.classList.toggle("nav-scrolled", window.scrollY > 24);
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      }

      function init() {
        initScrollAnimations();
        initNavbarScroll();
      }

      document.addEventListener("astro:page-load", init);
      init();
    </script>
  </body>
</html>
