---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import VideoSection from '../components/VideoSection.astro';
import HowItWorksSection from '../components/HowItWorksSection.astro';
import ProductSection from '../components/ProductSection.astro';
import UseCasesPreview from '../components/UseCasesPreview.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import SecuritySection from '../components/SecuritySection.astro';
import PartnersSection from '../components/PartnersSection.astro';
import MotivationSection from '../components/MotivationSection.astro';
import FAQSection from '../components/FAQSection.astro';
import ContactSection from '../components/ContactSection.astro';
---

<BaseLayout
  title="Enterprisebrain.eu — KI mit SAP-Integration"
  description="Maßgeschneiderte Unternehmens-KI mit vollständiger SAP-Integration. Prozesse automatisieren, Mitarbeitende entlasten, Effizienz steigern."
>
  <Navbar />
  <main>
    <HeroSection />
    <VideoSection />
    <HowItWorksSection />
    <ProductSection />
    <UseCasesPreview />
    <TestimonialsSection />
    <SecuritySection />
    <PartnersSection />
    <MotivationSection />
    <FAQSection />
    <ContactSection />
  </main>
  <Footer />
</BaseLayout>
