---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import UseCaseCard from "../../components/UseCaseCard.astro";
import { useTranslations, localePath } from "../../i18n/utils";

const lang = 'en' as const;
const t = useTranslations(lang);
const u = t.useCasesPage;
---

<BaseLayout
  title={u.metaTitle}
  description={u.metaDescription}
  lang={lang}
>
  <Navbar lang={lang} />

  <main>
    <section class="relative bg-white pt-36 pb-20 overflow-hidden">
      <div class="absolute inset-0 hero-grid opacity-60 pointer-events-none"></div>
      <div
        class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full pointer-events-none"
        style="background: radial-gradient(circle, rgba(242,146,2,0.07) 0%, transparent 65%); transform: translate(30%, -30%);"
      ></div>
      <div class="relative max-w-7xl mx-auto px-6">
        <span class="section-label animate-fade-in-up" style="animation-delay: 0.1s;">{u.heroLabel}</span>
        <span class="section-divider mt-3 mb-6 animate-fade-in-up" style="animation-delay: 0.2s;"></span>
        <h1
          class="text-[clamp(2.5rem,5.5vw,4.5rem)] font-display font-800 text-carbon mb-6 max-w-3xl text-balance animate-fade-in-up"
          style="animation-delay: 0.3s;"
        >
          {u.heroTitle}
        </h1>
        <p
          class="text-ash text-lg md:text-xl max-w-2xl leading-relaxed animate-fade-in-up"
          style="animation-delay: 0.45s;"
        >
          {u.heroSubtitle}
        </p>
      </div>
    </section>

    <section class="bg-white py-6">
      <div class="max-w-7xl mx-auto px-6">
        <UseCaseCard
          num={u.items[0].num}
          title={u.items[0].title}
          description={u.items[0].description}
          tag={u.items[0].tag}
          lang={lang}
        >
          <div class="uc01-video-wrap relative z-10 w-full">
            <video
              src="/usecases/ProfitabilityAnalyst.mov"
              autoplay
              muted
              loop
              playsinline
              class="uc01-video w-full block"
              style="aspect-ratio: 16/10; object-fit: cover;"></video>
            <button
              class="uc01-pause-btn absolute bottom-3 right-3 w-8 h-8 rounded-full flex items-center justify-center text-white transition-all hover:scale-110 active:scale-95"
              style="background: rgba(0,0,0,0.38); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);"
              aria-label="Pause"
              data-state="playing"
            >
              <svg class="uc01-icon-pause" width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"></path>
              </svg>
              <svg class="uc01-icon-play" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" style="margin-left:1px;">
                <path d="M8 5v14l11-7z"></path>
              </svg>
            </button>
          </div>
        </UseCaseCard>

        <UseCaseCard num={u.items[1].num} title={u.items[1].title} description={u.items[1].description} tag={u.items[1].tag} reversed lang={lang} />
        <UseCaseCard num={u.items[2].num} title={u.items[2].title} description={u.items[2].description} tag={u.items[2].tag} lang={lang} />
        <UseCaseCard num={u.items[3].num} title={u.items[3].title} description={u.items[3].description} tag={u.items[3].tag} reversed lang={lang} />
        <UseCaseCard num={u.items[4].num} title={u.items[4].title} description={u.items[4].description} tag={u.items[4].tag} lang={lang} />
        <UseCaseCard num={u.items[5].num} title={u.items[5].title} description={u.items[5].description} tag={u.items[5].tag} reversed lang={lang} />
      </div>
    </section>

    <section class="bg-snow py-20 relative overflow-hidden">
      <div class="absolute inset-0 hero-grid opacity-40 pointer-events-none"></div>
      <div class="relative max-w-3xl mx-auto px-6 text-center" data-animate>
        <h2 class="text-3xl md:text-4xl font-display font-800 text-carbon mb-5 text-balance">
          {u.ctaTitle}
        </h2>
        <p class="text-ash text-lg leading-relaxed mb-10">
          {u.ctaSubtitle}
        </p>
        <a href={localePath('/#kontakt', lang)} class="btn-primary">
          {u.ctaButton}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .uc01-pause-btn .uc01-icon-play { display: none; }
  .uc01-pause-btn[data-state="paused"] .uc01-icon-pause { display: none; }
  .uc01-pause-btn[data-state="paused"] .uc01-icon-play { display: block; }
</style>

<script>
  function initVideoControls() {
    const wraps = document.querySelectorAll<HTMLElement>(".uc01-video-wrap");
    wraps.forEach(function (wrap) {
      if (wrap.dataset.videoInitialized) return;
      wrap.dataset.videoInitialized = "true";
      const video = wrap.querySelector<HTMLVideoElement>("video");
      const btn = wrap.querySelector<HTMLButtonElement>(".uc01-pause-btn");
      if (!video || !btn) return;
      btn.addEventListener("click", function (e) {
        e.stopPropagation();
        if (video.paused) {
          video.play().catch(() => {});
          btn.setAttribute("data-state", "playing");
          btn.setAttribute("aria-label", "Pause");
        } else {
          video.pause();
          btn.setAttribute("data-state", "paused");
          btn.setAttribute("aria-label", "Play");
        }
      });
    });
  }
  document.addEventListener("astro:page-load", initVideoControls);
  initVideoControls();
</script>
