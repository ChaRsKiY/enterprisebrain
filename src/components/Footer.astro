---
---

<footer class="bg-snow border-t border-black/6">
  <div class="max-w-7xl mx-auto px-6 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-20 pb-14 border-b border-black/6">
      <div>
        <a href="/" class="flex items-center gap-3 mb-6">
          <img src="/logo.png" alt="vconsult Logo" width="36" height="36" class="object-contain" />
          <span class="font-display font-800 text-carbon text-base">Enterprisebrain.eu</span>
        </a>
        <p class="text-ash text-sm leading-relaxed mb-6 max-w-xs">
          Ein Produkt der vconsult Gruppe. Unternehmens-KI mit nahtloser SAP-Integration für nachhaltig mehr Effizienz.
        </p>
        <div class="space-y-1.5">
          <a href="mailto:office@enterprisebrain.eu" class="block text-sm text-ash hover:text-carbon transition-colors">
            office@enterprisebrain.eu
          </a>
          <a href="mailto:office@vconsult.at" class="block text-sm text-ash hover:text-carbon transition-colors">
            office@vconsult.at
          </a>
        </div>
        <div class="mt-6">
          <a
            href="https://www.linkedin.com/company/enterprisebrain"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex w-9 h-9 items-center justify-center rounded-lg border border-black/10 text-ash hover:text-carbon hover:border-primary/30 transition-all"
            aria-label="LinkedIn"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="section-label mb-5">Navigation</h3>
        <ul class="space-y-3">
          <li>
            <a href="/" class="text-sm text-ash hover:text-carbon transition-colors">Home</a>
          </li>
          <li>
            <a href="/use-cases" class="text-sm text-ash hover:text-carbon transition-colors">Use Cases</a>
          </li>
          <li>
            <a href="/#das-produkt" class="text-sm text-ash hover:text-carbon transition-colors">Das Produkt</a>
          </li>
          <li>
            <a href="/#kontakt" class="text-sm text-ash hover:text-carbon transition-colors">Kostenloses Erstgespräch</a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="section-label mb-5">Rechtliches</h3>
        <ul class="space-y-3">
          <li>
            <a href="/impressum" class="text-sm text-ash hover:text-carbon transition-colors">Impressum</a>
          </li>
          <li>
            <a href="/datenschutz" class="text-sm text-ash hover:text-carbon transition-colors">Datenschutz</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-ash/60">
        © {new Date().getFullYear()} Enterprisebrain.eu — Ein Produkt der vconsult Gruppe. Alle Rechte vorbehalten.
      </p>
      <div class="flex items-center gap-1.5">
        <span class="text-xs text-ash/40">Powered by</span>
        <a href="https://vconsult.at" target="_blank" rel="noopener noreferrer" class="text-xs text-ash hover:text-carbon transition-colors font-display font-600">
          vconsult
        </a>
      </div>
    </div>
  </div>
</footer>
