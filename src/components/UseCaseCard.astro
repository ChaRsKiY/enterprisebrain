---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  num: string;
  title: string;
  description: string;
  tag: string;
  reversed?: boolean;
  lang?: Lang;
}

const { num, title, description, tag, reversed = false, lang = 'de' } = Astro.props;
const t = useTranslations(lang);

const tagColors: Record<string, string> = {
  Analyse: 'bg-blue-50 text-blue-600 border border-blue-200',
  Analysis: 'bg-blue-50 text-blue-600 border border-blue-200',
  Automatisierung: 'bg-primary/8 text-primary border border-primary/20',
  Automation: 'bg-primary/8 text-primary border border-primary/20',
  Support: 'bg-secondary/10 text-[#c4642a] border border-secondary/30',
};
---

<article
  id={`uc-${num}`}
  class={`grid lg:grid-cols-2 gap-10 lg:gap-20 items-center py-16 border-b border-black/6 last:border-0 scroll-mt-32 ${reversed ? 'lg:[&>*:first-child]:order-2' : ''}`}
  data-animate
>
  <div>
    <div class="flex items-center gap-4 mb-6">
      <span
        class="font-display font-800 text-6xl leading-none select-none"
        style="color: rgba(0,0,0,0.05);"
        aria-hidden="true"
      >
        {num}
      </span>
      <div>
        <span
          class={`inline-flex items-center px-2.5 py-1 rounded-full text-[0.6rem] font-display font-700 tracking-widest uppercase ${tagColors[tag] ?? 'bg-snow text-ash border border-black/10'}`}
        >
          {tag}
        </span>
        <div class="flex items-center gap-2 mt-2">
          <span class="w-1.5 h-1.5 rounded-full bg-primary" style="box-shadow: 0 0 5px rgba(242,146,2,0.7);"></span>
          <span class="text-xs font-display font-600 text-primary tracking-wide">{t.useCaseCard.liveLabel}</span>
        </div>
      </div>
    </div>

    <span class="section-divider mb-5"></span>
    <h2 class="text-2xl md:text-3xl font-display font-800 text-carbon mb-5 text-balance">
      {title}
    </h2>
    <p class="text-ash leading-relaxed">{description}</p>
  </div>

  <div class="relative">
    <div
      class="rounded-2xl border border-black/7 bg-snow relative overflow-hidden"
    >
      <div class="absolute inset-0 hero-grid opacity-50 rounded-2xl pointer-events-none"></div>
      <div
        class="absolute top-4 right-4 w-24 h-24 rounded-full pointer-events-none"
        style="background: radial-gradient(circle, rgba(242,146,2,0.08) 0%, transparent 65%);"
      ></div>
      {
        Astro.slots.has('default') ? (
          <slot />
        ) : (
          <div class="relative z-10 flex flex-col items-center justify-center aspect-[16/10] text-center p-8 bg-snow/50 backdrop-blur-sm">
            <div class="w-16 h-16 mb-4 rounded-full bg-black/5 flex items-center justify-center shadow-inner">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-ash/60">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
              </svg>
            </div>
            <span class="font-display font-600 text-carbon/60 text-lg uppercase tracking-wider mb-2">Preview</span>
            <span class="text-ash/60 text-sm">Coming Soon</span>
          </div>
        )
      }
    </div>
  </div>
</article>
