---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang);
const m = t.motivation;
---

<section class="bg-snow py-24 lg:py-36 relative overflow-hidden">
  <div class="absolute inset-0 dot-grid pointer-events-none"></div>

  <div
    class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(242,146,2,0.05) 0%, transparent 65%);"
  ></div>

  <div class="relative max-w-4xl mx-auto px-6 text-center">
    <span class="section-label" data-animate>{m.label}</span>
    <span class="section-divider mx-auto my-4 block" data-animate data-animate-delay="1"></span>
    <h2 class="text-4xl md:text-5xl font-display font-800 text-carbon mt-4 mb-10 text-balance" data-animate data-animate-delay="2">
      {m.title}
    </h2>

    <div class="space-y-6 text-ash text-lg leading-relaxed" data-animate data-animate-delay="3">
      <p>{m.p1}</p>
      <p>{m.p2}</p>
    </div>

    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-10 sm:gap-16" data-animate data-animate-delay="4">
      <div class="flex flex-col items-center gap-3">
        <div class="w-12 h-12 rounded-full gradient-bg flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
          </svg>
        </div>
        <div>
          <div class="font-display font-700 text-carbon text-sm">{m.stat1Title}</div>
          <div class="text-ash text-xs mt-0.5">{m.stat1Sub}</div>
        </div>
      </div>
      <div class="flex flex-col items-center gap-3">
        <div class="w-12 h-12 rounded-full gradient-bg flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <div>
          <div class="font-display font-700 text-carbon text-sm">{m.stat2Title}</div>
          <div class="text-ash text-xs mt-0.5">{m.stat2Sub}</div>
        </div>
      </div>
      <div class="flex flex-col items-center gap-3">
        <div class="w-12 h-12 rounded-full gradient-bg flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <div>
          <div class="font-display font-700 text-carbon text-sm">{m.stat3Title}</div>
          <div class="text-ash text-xs mt-0.5">{m.stat3Sub}</div>
        </div>
      </div>
    </div>
  </div>
</section>
