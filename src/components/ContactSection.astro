---
import ContactForm from './ContactForm';
---

<section id="kontakt" class="bg-parchment py-24 lg:py-36 relative overflow-hidden">
  <div class="absolute inset-0 hero-grid opacity-40 pointer-events-none"></div>
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(242,146,2,0.07) 0%, transparent 65%);"
  ></div>

  <div class="relative max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">
      <div data-animate>
        <span class="section-label">Erstgespräch</span>
        <span class="section-divider mt-3 mb-6"></span>
        <h2 class="text-4xl md:text-[2.8rem] font-display font-800 text-carbon mb-6 text-balance leading-tight">
          Kostenloses Erstgespräch für KI-Lösungen mit SAP Plugin
        </h2>
        <p class="text-ash text-lg leading-relaxed mb-10">
          Optimieren Sie Ihre Geschäftsprozesse mit maßgeschneiderten KI-Lösungen. In einem unverbindlichen Gespräch analysieren wir Ihre spezifischen Anforderungen.
        </p>

        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-lg gradient-bg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <div>
              <div class="font-display font-700 text-carbon text-sm">Keine Verpflichtung</div>
              <div class="text-ash text-sm mt-0.5">Das Erstgespräch ist vollständig kostenlos und unverbindlich</div>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-lg gradient-bg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <div class="font-display font-700 text-carbon text-sm">Schnelle Reaktion</div>
              <div class="text-ash text-sm mt-0.5">Wir melden uns innerhalb von 24 Stunden bei Ihnen</div>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 rounded-lg gradient-bg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <div>
              <div class="font-display font-700 text-carbon text-sm">Individuelle Beratung</div>
              <div class="text-ash text-sm mt-0.5">Maßgeschneiderte Lösungen für Ihre SAP-Umgebung</div>
            </div>
          </div>
        </div>
      </div>

      <div data-animate data-animate-delay="2">
        <ContactForm client:visible />
      </div>
    </div>
  </div>
</section>
