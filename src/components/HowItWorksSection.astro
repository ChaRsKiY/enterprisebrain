---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'de' } = Astro.props;
const t = useTranslations(lang);
const h = t.howItWorks;
---

<section id="wie-es-funktioniert" class="bg-white py-24 lg:py-32 relative overflow-hidden">
  <div class="absolute inset-0 hero-grid opacity-40 pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6">
    <div class="text-center mb-16" data-animate>
      <span class="section-label">{h.label}</span>
      <div class="section-divider mx-auto my-4"></div>
      <h2 class="text-3xl md:text-4xl font-display font-800 text-carbon mt-4">
        {h.titlePrefix} <span class="gradient-text">{h.titleHighlight}</span>
      </h2>
      <p class="text-ash text-lg mt-4 max-w-xl mx-auto leading-relaxed">
        {h.subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:flex lg:flex-row lg:items-stretch gap-6 lg:gap-4">
      {h.steps.map((step, i) => (
        <Fragment>
          <div
            class="lg:flex-1 flex flex-col p-7 rounded-2xl bg-snow border border-black/6 hover:border-primary/20 transition-colors duration-300"
            data-animate
            data-animate-delay={String(i + 1)}
          >
            <span class="font-display font-800 text-[2.5rem] leading-none gradient-text opacity-60 mb-6 block">
              {step.number}
            </span>
            <div class="w-8 h-0.5 gradient-bg rounded-full mb-4"></div>
            <h3 class="font-display font-700 text-carbon text-base mb-3 leading-snug">
              {step.title}
            </h3>
            <p class="text-ash text-sm leading-relaxed">
              {step.description}
            </p>
          </div>
          {i < h.steps.length - 1 && (
            <div class="hidden lg:flex items-center justify-center flex-shrink-0 w-5 text-primary/30">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}
        </Fragment>
      ))}
    </div>
  </div>
</section>
